# Copie este arquivo para ".env" e preencha os valores.

# Porta onde o servidor irá rodar (padrão 3000)
PORT=3000

# Sessão (mantém o fluxo de login entre requisições)
SESSION_SECRET=uma-chave-secreta-muito-forte

# Configurações de e-mail (usado para enviar o código 2FA)
# Exemplo (Gmail):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=seu.email@gmail.com
# EMAIL_PASS=senha-do-app-ou-senha

EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=

# lista de usuários válidos (para teste) no formato
# "email:senha" separados por vírgula.
# Ex: TEST_USERS=joao@exemplo.com:senha123,maria@exemplo.com:qwerty
TEST_USERS=

# OAuth Google (para login com conta Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# OAuth Facebook (para login com conta Facebook)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

# Banco de dados (SQLite)
# O arquivo será criado automaticamente.
DB_PATH=./users.db
